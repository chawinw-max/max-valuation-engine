# .streamlit/secrets.toml — Copy this to secrets.toml and fill in real values
# On Streamlit Cloud: paste these into the "Secrets" section in app settings

GEMINI_API_KEY = "your-gemini-api-key-here"
DRIVE_TEMPLATE_FILE_ID = "your-google-drive-template-file-id"
DRIVE_OUTPUT_FOLDER_ID = "your-google-drive-output-folder-id"

# Paste the full service account JSON as a single string:
SERVICE_ACCOUNT_JSON = '{"type": "service_account", "project_id": "...", "private_key": "...", ...}'
